<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Make More Possible</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH" crossorigin="anonymous">
</head>
<body class="bg-light">
    <div class="container mt-5">
        <div class="row justify-content-center">
            <div class="col-md-8">
                <div class="card shadow">
                    <div class="card-body">
                        <h1 class="card-title text-center mb-4">Make More Possible</h1>
                        <form id="questionForm" action="/ask" method="POST">
                            <div class="mb-3">
                                <label for="question" class="form-label">Your Question:</label>
                                <textarea class="form-control" name="question" id="question" rows="4" placeholder="Enter your question here..."></textarea>
                            </div>
                            <div class="d-grid">
                                <button type="submit" class="btn btn-primary btn-lg">Submit</button>
                            </div>
                        </form>
                        <div id="spinner" class="text-center mt-4" style="display: none;">
                            <div class="spinner-border text-primary" role="status">
                                <span class="visually-hidden">Loading...</span>
                            </div>
                            <p class="mt-2">Thinking...</p>
                        </div>
                        <div id="answerContainer" class="mt-4" style="display: none;">
                            <h2>Answer:</h2>
                            <div class="alert alert-info" id="answerContent">
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js" integrity="sha384-YvpcrYf0tY3lHB60NNkmXc5s9fDVZLESaAA55NDzOxhy9GkcIdslK1eN7N6jIeHz" crossorigin="anonymous"></script>
    <script>
        document.getElementById('questionForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            const params = new URLSearchParams();
            params.append('question', document.getElementById('question').value);
            document.getElementById('spinner').style.display = 'block';
            document.getElementById('answerContainer').style.display = 'none';
            try {
                const response = await fetch('/ask', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded'
                    },
                    body: params.toString()
                });
                const data = await response.json();
                document.getElementById('answerContent').innerHTML = data.answer;
                document.getElementById('answerContainer').style.display = 'block';
            } catch (error) {
                document.getElementById('answerContent').innerHTML = '<p>Error: ' + error.message + '</p>';
                document.getElementById('answerContainer').style.display = 'block';
            }
            document.getElementById('spinner').style.display = 'none';
        });
    </script>
</body>
</html>